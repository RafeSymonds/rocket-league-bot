#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from rocket_league_bot_src.reporting import write_training_report
from rocket_league_bot_src.checkpoints import find_latest_compatible_checkpoint
from rocket_league_bot_src.eval import maybe_refresh_eval_summary


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Render the training HTML report.")
    parser.add_argument("--x-axis", choices=("iteration", "time"), default="iteration")
    parser.add_argument("--max-rows", type=int, default=160)
    parser.add_argument("--max-age-hours", type=float, default=12.0)
    parser.add_argument("--no-auto-eval", action="store_true")
    parser.add_argument("--eval-episodes", type=int, default=6)
    parser.add_argument("--eval-device", default="gpu")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    latest_checkpoint = find_latest_compatible_checkpoint("data/checkpoints")
    _, eval_error, _ = maybe_refresh_eval_summary(
        latest_checkpoint=latest_checkpoint,
        episodes=args.eval_episodes,
        device=args.eval_device,
        disabled=bool(args.no_auto_eval),
    )
    write_training_report(
        x_axis=args.x_axis,
        max_rows=args.max_rows,
        max_age_hours=args.max_age_hours,
        eval_error=eval_error,
    )
    print("Wrote data/training_report.html")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
