#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

import argparse
import json
import shutil
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from rocket_league_bot_src.checkpoints import find_latest_compatible_checkpoint
from rocket_league_bot_src.export import export_checkpoint_to_rlbot_package


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Export the latest trained checkpoint into the RLBot package.")
    parser.add_argument("--checkpoint-root", default="data/checkpoints")
    parser.add_argument("--checkpoint-dir", default="")
    parser.add_argument("--bot-dir", default="BotBoi_v1/src")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    checkpoint_dir = args.checkpoint_dir or find_latest_compatible_checkpoint(args.checkpoint_root)
    if not checkpoint_dir:
        raise SystemExit("No checkpoint found to export")

    src = Path(checkpoint_dir)
    bot_dir = Path(args.bot_dir)
    export_checkpoint_to_rlbot_package(str(src), str(bot_dir))
    runtime_config = json.loads((bot_dir / "runtime_config.json").read_text())

    print(f"Exported checkpoint to {bot_dir}")
    print(f"source={src}")
    print(f"timesteps={runtime_config['cumulative_timesteps']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
