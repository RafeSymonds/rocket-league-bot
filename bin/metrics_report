#!/usr/bin/env python3
from __future__ import annotations

import csv
import sys
from pathlib import Path


def _avg(rows, key: str) -> float:
    vals = [float(r[key]) for r in rows if r.get(key, "") != ""]
    return sum(vals) / len(vals) if vals else 0.0


def main() -> int:
    path = Path(sys.argv[1]) if len(sys.argv) > 1 else Path("data/training_metrics.csv")
    if not path.exists():
        print(f"Missing metrics file: {path}")
        return 1

    with path.open("r", encoding="utf-8") as f:
        rows = list(csv.DictReader(f))

    if not rows:
        print("Metrics file is empty")
        return 0

    show = rows[-12:]
    print("stage | difficulty | avg_return | touch_rate | goal_rate | blue_goal_rate | ema_touch | ema_goal")
    print("-" * 80)
    for r in show:
        print(
            f"{r['stage']:<8} | "
            f"{float(r['difficulty']):10.3f} | "
            f"{float(r['avg_return']):10.2f} | "
            f"{float(r['touch_rate']):10.3f} | "
            f"{float(r['goal_rate']):9.3f} | "
            f"{float(r.get('blue_goal_rate', 0.0)):14.3f} | "
            f"{float(r['ema_touch']):9.3f} | "
            f"{float(r['ema_goal']):8.3f}"
        )

    n = len(rows)
    w = min(8, n)
    recent = rows[-w:]
    prev = rows[-2 * w : -w] if n >= 2 * w else rows[: max(1, n - w)]

    recent_return = _avg(recent, "avg_return")
    prev_return = _avg(prev, "avg_return")
    recent_touch = _avg(recent, "touch_rate")
    prev_touch = _avg(prev, "touch_rate")
    recent_goal = _avg(recent, "goal_rate")
    prev_goal = _avg(prev, "goal_rate")
    recent_blue_goal = _avg(recent, "blue_goal_rate")
    prev_blue_goal = _avg(prev, "blue_goal_rate")
    recent_difficulty = _avg(recent, "difficulty")
    prev_difficulty = _avg(prev, "difficulty")

    print("\nTrend")
    print(f"avg_return: {prev_return:.2f} -> {recent_return:.2f} (delta {recent_return - prev_return:+.2f})")
    print(f"touch_rate: {prev_touch:.3f} -> {recent_touch:.3f} (delta {recent_touch - prev_touch:+.3f})")
    print(f"goal_rate : {prev_goal:.3f} -> {recent_goal:.3f} (delta {recent_goal - prev_goal:+.3f})")
    print(f"blue_goal : {prev_blue_goal:.3f} -> {recent_blue_goal:.3f} (delta {recent_blue_goal - prev_blue_goal:+.3f})")
    print(f"difficulty: {prev_difficulty:.3f} -> {recent_difficulty:.3f} (delta {recent_difficulty - prev_difficulty:+.3f})")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
