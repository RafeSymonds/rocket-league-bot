#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

import csv
import json
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from rocket_league_bot_src.checkpoints import (
    find_latest_compatible_checkpoint,
    load_checkpoint_book,
)
from rocket_league_bot_src.eval import maybe_refresh_eval_summary


def parse_args():
    import argparse

    parser = argparse.ArgumentParser(description="Show current training / export status.")
    parser.add_argument("--watch", type=float, default=0.0, help="Refresh every N seconds.")
    parser.add_argument("--no-auto-eval", action="store_true")
    parser.add_argument("--eval-episodes", type=int, default=6)
    parser.add_argument("--eval-device", default="gpu")
    return parser.parse_args()


def read_metrics(path: Path) -> list[dict[str, str]]:
    if not path.exists():
        return []
    with path.open("r", encoding="utf-8") as handle:
        return list(csv.DictReader(handle))


def render(args) -> None:
    checkpoint_root = Path("data/checkpoints")
    metrics_path = Path("data/training_metrics.csv")
    league_path = Path("data/league/snapshots.json")
    opponent_state_path = Path("data/opponent_state.json")
    eval_summary_path = Path("data/eval/latest_summary.json")
    runtime_config_path = Path("BotBoi_v1/src/runtime_config.json")

    latest_checkpoint = find_latest_compatible_checkpoint(str(checkpoint_root))
    eval_error = ""
    eval_refreshed = False
    print("Latest compatible checkpoint:")
    if latest_checkpoint:
        book = load_checkpoint_book(latest_checkpoint)
        print(f"  dir: {latest_checkpoint}")
        print(f"  timesteps: {int(book.get('cumulative_timesteps', 0))}")
        reward_raw = book.get("policy_average_reward", 0.0)
        reward = 0.0 if reward_raw is None else float(reward_raw)
        print(f"  avg_reward: {reward:.3f}")
    else:
        print("  none")

    eval_summary, eval_error, eval_refreshed = maybe_refresh_eval_summary(
        latest_checkpoint=latest_checkpoint,
        episodes=args.eval_episodes,
        device=args.eval_device,
        disabled=bool(args.no_auto_eval),
    )

    rows = read_metrics(metrics_path)
    print("\nTraining metrics:")
    if rows:
        last = rows[-1]
        print(f"  stage: {last.get('stage', '')}")
        print(f"  difficulty: {last.get('difficulty', '')}")
        print(f"  touch_rate: {last.get('touch_rate', '')}")
        print(f"  goal_rate: {last.get('goal_rate', '')}")
        print(f"  blue_goal_rate: {last.get('blue_goal_rate', '')}")
        print(f"  median_t_first: {last.get('median_t_first', '')}")
        print(f"  median_t_goal: {last.get('median_t_goal', '')}")
    else:
        print("  no metrics yet")

    print("\nLeague snapshots:")
    if league_path.exists():
        snapshots = json.loads(league_path.read_text())
        print(f"  count: {len(snapshots)}")
        if snapshots:
            latest = snapshots[-1]
            print(f"  latest ts: {latest.get('cumulative_timesteps', 0)}")
            print(f"  latest stage: {latest.get('stage', '')}")
    else:
        print("  none")

    print("\nOpponent state:")
    if opponent_state_path.exists():
        opponent = json.loads(opponent_state_path.read_text())
        print(f"  enabled: {'yes' if opponent.get('enabled') else 'no'}")
        print(f"  checkpoint: {opponent.get('checkpoint_dir', '')}")
        print(f"  gap_ts: {opponent.get('gap_ts', '')}")
        print(f"  blue_goal_rate: {opponent.get('blue_goal_rate', '')}")
    else:
        print("  none")

    print("\nEvaluation ladder:")
    if eval_summary is not None:
        summary = eval_summary
        print(f"  auto_refreshed: {'yes' if eval_refreshed else 'no'}")
        print(f"  current_ts: {summary.get('current_timesteps', 0)}")
        print(f"  stage: {summary.get('stage', '')}")
        print(f"  avg_blue_win_rate: {summary.get('avg_blue_win_rate', 0.0):.3f}")
        print(f"  avg_goal_diff_per_episode: {summary.get('avg_goal_diff_per_episode', 0.0):.3f}")
        print(f"  anchor_count: {summary.get('anchor_count', 0)}")
        print(f"  refresh_after_ts: {summary.get('refresh_after_timesteps', 0)}")
    elif eval_summary_path.exists():
        summary = json.loads(eval_summary_path.read_text())
        stale = latest_checkpoint and str(summary.get("current_checkpoint_dir", "")) != latest_checkpoint
        print(f"  auto_refreshed: no")
        print(f"  stale: {'yes' if stale else 'no'}")
        print(f"  current_ts: {summary.get('current_timesteps', 0)}")
        print(f"  stage: {summary.get('stage', '')}")
        print(f"  avg_blue_win_rate: {summary.get('avg_blue_win_rate', 0.0):.3f}")
        print(f"  avg_goal_diff_per_episode: {summary.get('avg_goal_diff_per_episode', 0.0):.3f}")
        print(f"  anchor_count: {summary.get('anchor_count', 0)}")
        print(f"  refresh_after_ts: {summary.get('refresh_after_timesteps', 0)}")
        if eval_error:
            print(f"  refresh_error: {eval_error}")
    elif eval_error:
        print(f"  error: {eval_error}")
    else:
        print("  none")

    print("\nRLBot package:")
    if runtime_config_path.exists():
        runtime = json.loads(runtime_config_path.read_text())
        checkpoint_dir = runtime.get("checkpoint_dir", "")
        checkpoint_exists = Path(checkpoint_dir).exists() if checkpoint_dir else False
        print(f"  checkpoint: {checkpoint_dir}")
        print(f"  timesteps: {runtime.get('cumulative_timesteps', 0)}")
        print(f"  action_repeat: {runtime.get('action_repeat', '')}")
        print(f"  obs_dim: {runtime.get('obs_dim', '')}")
        print(f"  stale: {'no' if checkpoint_exists else 'yes'}")
    else:
        print("  no exported runtime_config.json")


def main() -> int:
    args = parse_args()
    if args.watch and args.watch > 0:
        while True:
            print("\033[2J\033[H", end="")
            render(args)
            time.sleep(args.watch)
    render(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
