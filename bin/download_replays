#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/replay-env/bin/python" ]; then
  exec "$ROOT_DIR/replay-env/bin/python" "$0" "$@"
fi
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

"""
Download Rocket League replays from ballchasing API and parse them into training-ready format.

Usage:
    python bin/download_replays.py --api-token YOUR_TOKEN --output data/replays --playlist ranked-duels --count 1000
"""

import argparse
import json
import os
import shutil
import time
from pathlib import Path

try:
    import ballchasing as bc
    import carball
    from carball.analysis.saltie_game.saltie_game import SaltieGame
    from tqdm import tqdm
except ImportError as exc:
    raise SystemExit(
        "Replay download dependencies are not installed.\n"
        "Run `bin/setup_replay_env` once, then rerun this command.\n"
        "If setup fails, install a compatible replay Python via pyenv and rerun `bin/setup_replay_env`.\n"
        f"Details: {exc}"
    )


def load_dotenv(dotenv_path: Path) -> dict[str, str]:
    values = {}
    if not dotenv_path.exists():
        return values
    for raw_line in dotenv_path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip().strip("'").strip('"')
        if key:
            values[key] = value
    return values


def get_replays_by_playlist(api: bc.Api, playlist: str, min_rank: str = "supersonic-legend", count: int = 1000):
    """Get replays from ballchasing API."""
    replays = []
    for replay in api.get_replays(playlist=playlist, min_rank=min_rank, count=count):
        replays.append({
            "id": replay["id"],
            "rocket_league_id": replay["rocket_league_id"],
            "playlist": replay["playlist_id"],
            "date": replay["date"],
            "min_rank": replay["min_rank"],
            "max_rank": replay["max_rank"],
        })
    return replays


def export_parsed_replay(analysis, parquet_folder: Path) -> None:
    game = analysis.game
    parquet_folder.mkdir(parents=True, exist_ok=True)

    metadata = {
        "players": [
            {
                "name": player.name,
                "unique_id": str(player.online_id),
            }
            for player in game.players
        ],
        "game": {
            "goals": [
                {
                    "frame": int(goal.frame_number),
                    "player_name": goal.player_name,
                    "is_orange": bool(goal.player_team),
                }
                for goal in game.goals
            ]
        },
    }

    proto_game = analysis.get_protobuf_data()
    hits = [
        {
            "frame_number": int(hit.frame_number),
            "player_unique_id": str(hit.player_id.id),
        }
        for hit in proto_game.game_stats.hits
    ]

    kickoff_frames = [int(frame) for frame in SaltieGame.get_kickoff_frames(game)]
    goal_frames = sorted(int(goal.frame_number) for goal in game.goals)
    gameplay_periods = []
    for start_frame in kickoff_frames:
        goal_frame = next((frame for frame in goal_frames if frame > start_frame), None)
        gameplay_periods.append({
            "start_frame": start_frame,
            "goal_frame": goal_frame,
        })

    analyzer = {
        "hits": hits,
        "gameplay_periods": gameplay_periods,
    }

    (parquet_folder / "metadata.json").write_text(json.dumps(metadata, indent=2))
    (parquet_folder / "analyzer.json").write_text(json.dumps(analyzer, indent=2))

    game.ball.to_pickle(parquet_folder / "__ball.pkl")
    game.frames.to_pickle(parquet_folder / "__game.pkl")
    for player in game.players:
        player.data.to_pickle(parquet_folder / f"player_{player.online_id}.pkl")


def download_and_parse_replay(api: bc.Api, replay_id: str, output_folder: Path, playlist: str) -> tuple[bool, str]:
    """Download a single replay and parse it with carball."""
    replay_folder = output_folder / playlist / replay_id
    replay_path = replay_folder / f"{replay_id}.replay"
    parquet_folder = replay_folder / "parquet"
    try:
        replay_folder.mkdir(parents=True, exist_ok=True)

        if parquet_folder.exists() and (
            (parquet_folder / "__ball.parquet").exists()
            or (parquet_folder / "__ball.pkl").exists()
        ):
            print(f"  Skipping {replay_id} (already parsed)")
            return True, "already_parsed"

        api.download_replay(replay_id, str(replay_folder))

        if not replay_path.exists():
            print(f"  Failed to download {replay_id}")
            return False, "download_failed"

        analysis = carball.analyze_replay_file(str(replay_path))
        export_parsed_replay(analysis, parquet_folder)
        proto_data = analysis.get_protobuf_data()

        proto_path = parquet_folder / "game.proto"
        with open(proto_path, "wb") as f:
            proto_data.write_to(f)

        return True, "ok"

    except Exception as e:
        if parquet_folder.exists():
            shutil.rmtree(parquet_folder, ignore_errors=True)
        print(f"  Error processing {replay_id}: {e}")
        return False, str(e)


def main():
    root_dir = Path(__file__).resolve().parents[1]
    dotenv_values = load_dotenv(root_dir / ".env")

    parser = argparse.ArgumentParser(description="Download and parse RL replays")
    parser.add_argument(
        "--api-token",
        default="",
        help="ballchasing.com API token. Defaults to BALLCHASING_API_TOKEN from .env or the shell.",
    )
    parser.add_argument("--output", default="data/replays", help="Output folder for replays")
    parser.add_argument("--playlist", default="ranked-duels", 
                        choices=["ranked-duels", "ranked-doubles", "ranked-standard"],
                        help="Playlist to download")
    parser.add_argument("--count", type=int, default=1000, help="Number of replays to download")
    parser.add_argument("--min-rank", default="supersonic-legend", help="Minimum rank filter")
    parser.add_argument("--rate-limit", type=int, default=10, help="Requests per second limit")
    
    args = parser.parse_args()

    api_token = (
        args.api_token.strip()
        or os.environ.get("BALLCHASING_API_TOKEN", "").strip()
        or os.environ.get("BALLCHASING_TOKEN", "").strip()
        or dotenv_values.get("BALLCHASING_API_TOKEN", "").strip()
        or dotenv_values.get("BALLCHASING_TOKEN", "").strip()
    )
    if not api_token:
        raise SystemExit(
            "Missing ballchasing API token.\n"
            "Set BALLCHASING_API_TOKEN in .env or pass --api-token."
        )

    api = bc.Api(api_token)
    output_folder = Path(args.output)
    
    print(f"Fetching replay list for {args.playlist} (min rank: {args.min_rank})...")
    replays = get_replays_by_playlist(api, args.playlist, args.min_rank, args.count)
    print(f"Found {len(replays)} replays")
    
    playlist_folder = output_folder / args.playlist
    playlist_folder.mkdir(parents=True, exist_ok=True)
    
    metadata_file = playlist_folder / "_metadata.json"
    if metadata_file.exists():
        existing = json.loads(metadata_file.read_text())
        downloaded_ids = set(existing.get("replay_ids", []))
        skipped_ids = existing.get("skipped_replay_ids", {})
    else:
        downloaded_ids = set()
        skipped_ids = {}

    def write_metadata() -> None:
        metadata = {
            "playlist": args.playlist,
            "count": len(downloaded_ids),
            "replay_ids": sorted(downloaded_ids),
            "skipped_replay_ids": skipped_ids,
        }
        metadata_file.write_text(json.dumps(metadata, indent=2, sort_keys=True))
    
    for replay in tqdm(replays, desc="Downloading replays"):
        replay_id = replay["id"]
        
        if replay_id in downloaded_ids or replay_id in skipped_ids:
            continue

        success, reason = download_and_parse_replay(api, replay_id, output_folder, args.playlist)

        if success:
            downloaded_ids.add(replay_id)
        else:
            skipped_ids[replay_id] = reason

        write_metadata()
        
        time.sleep(1.0 / args.rate_limit)
    
    print(f"Done! Downloaded {len(downloaded_ids)} replays to {output_folder}")


if __name__ == "__main__":
    main()
