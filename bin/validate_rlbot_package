#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from rocket_league_bot_src.export import summarize_rlbot_package


def main() -> int:
    bot_dir = ROOT / "BotBoi_v1" / "src"
    summary = summarize_rlbot_package(str(bot_dir))
    missing = summary["missing"]
    if missing:
        print("Missing files:")
        for path in missing:
            print(f"  {path}")
        return 1

    runtime = summary["runtime"]
    book = summary["book"]

    print("RLBot package looks complete.")
    print(f"checkpoint={runtime.get('checkpoint_dir', '')}")
    print(f"timesteps={runtime.get('cumulative_timesteps', 0)}")
    print(f"policy_average_reward={runtime.get('policy_average_reward', 0.0)}")
    print(f"obs_dim={runtime.get('obs_dim', '')}")
    print(f"action_repeat={runtime.get('action_repeat', '')}")
    print(f"book_timesteps={book.get('cumulative_timesteps', 0)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
