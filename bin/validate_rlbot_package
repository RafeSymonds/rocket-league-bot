#!/bin/sh
""":"
ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
if [ -x "$ROOT_DIR/env/bin/python" ]; then
  exec "$ROOT_DIR/env/bin/python" "$0" "$@"
fi
exec python3 "$0" "$@"
":"""
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))


def main() -> int:
    bot_dir = ROOT / "BotBoi_v1" / "src"
    required = [
        bot_dir / "bot.py",
        bot_dir / "bot.cfg",
        bot_dir / "appearance.cfg",
        bot_dir / "PPO_POLICY.pt",
        bot_dir / "BOOK_KEEPING_VARS.json",
        bot_dir / "runtime_config.json",
    ]

    missing = [str(path) for path in required if not path.exists()]
    if missing:
        print("Missing files:")
        for path in missing:
            print(f"  {path}")
        return 1

    runtime = json.loads((bot_dir / "runtime_config.json").read_text())
    book = json.loads((bot_dir / "BOOK_KEEPING_VARS.json").read_text())

    print("RLBot package looks complete.")
    print(f"checkpoint={runtime.get('checkpoint_dir', '')}")
    print(f"timesteps={runtime.get('cumulative_timesteps', 0)}")
    print(f"policy_average_reward={runtime.get('policy_average_reward', 0.0)}")
    print(f"obs_dim={runtime.get('obs_dim', '')}")
    print(f"action_repeat={runtime.get('action_repeat', '')}")
    print(f"book_timesteps={book.get('cumulative_timesteps', 0)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
